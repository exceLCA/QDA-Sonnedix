# Anthropic API key used server-side by /api/analyze for document compliance analysis.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Shared password gate (HTTP Basic Auth) for the client-facing demo link. Any username works,
# only the password is checked. Leave unset to skip the prompt during local dev.
SITE_PASSWORD=choose-a-shared-password
